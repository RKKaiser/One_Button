# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore

# =============== #
# Unity generated #
# =============== #
Temp/
[Ll]ibrary/
[Bb]uild/
[Bb]uilds/
Assets/AssetStoreTools*

# ===================================== #
# Visual Studio / MonoDevelop generated #
# ===================================== #
ExportedObj/
obj/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ============ #
# OS generated #
# ============ #
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============== #
# Rider / Resharper #
# ============== #
.idea/
*.sln.iml

# ============== #
# JetBrains Rider #
# ============== #
**/.idea/
**/*.sln.iml

# ================= #
# Visual Studio Code #
# ================= #
.vscode/

# =============== #
# Unity specific  #
# =============== #
/[Aa]ssets/[Aa]ssetStoreTools*
/[Aa]ssets/AssetStoreTools*

# Asset meta data should only be kept when using external tools that require it.
# Generally you should keep them, but if you're using submodules or nested repositories,
# you can comment the next line.
/[Aa]ssets/**/*.meta

# ============================= #
# MonoDevelop / Xamarin Studio  #
# ============================= #
*.pidb
*.userprefs

# ======== #
# TextMesh Pro #
# ======== #
Assets/TextMesh Pro/Resources/Fonts & Materials/
Assets/TextMesh Pro/Examples & Extras/
Assets/TextMesh Pro/Documentation/